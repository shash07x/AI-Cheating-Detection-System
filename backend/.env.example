# ===== AI Cheating Detection - Environment Variables =====

# Google Gemini API Key (Required for AI text detection)
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask
SECRET_KEY=change-this-to-a-random-secret-key

# Deployed candidate app URL (used to generate session join links)
# Set this to your Vercel deployment URL of the candidate-app
CANDIDATE_APP_URL=https://your-candidate-app.vercel.app
